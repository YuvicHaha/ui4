            else
                screenButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                screenButton.TextColor3 = Color3.fromRGB(160, 160, 160)
            end
        end
    end

    local function FireToggle(skipCallback)
    if not skipCallback then
        ToggleEnabled = not ToggleEnabled
    end
    
    -- [TRACKING LOGIC]: Save the state using the toggle's name
    UI_States.Toggles[togglename] = ToggleEnabled

    local targetX = ToggleEnabled and 0.455 or 0.123
    ToggleBall:TweenPosition(UDim2.new(targetX, 0, 0, 3.5), "Out", "Linear", 0.1, true)
    
    if not ToggleEnabled and closeColorPanel then
        closeColorPanel()
    end
    
    UpdateScreenButtonVisuals()
    pcall(callback, ToggleEnabled)
end

    ToggleButton.MouseButton1Down:Connect(function() FireToggle(false) end)

    if isMobile then
        BindButton.MouseButton1Down:Connect(function()
            if screenButton then
                if mobileDragConn then mobileDragConn:Disconnect(); mobileDragConn = nil end
                screenButton:Destroy()
                screenButton = nil
                BindButton.Text = "Show"
                BindButton.TextColor3 = Color3.fromRGB(150, 150, 150)
            else
                BindButton.Text = "Hide"
                BindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                
                screenButton = Instance.new("TextButton")
                local screenCorner = Instance.new("UICorner")
                
                screenButton.Name = (togglename or "Toggle") .. "_Shortcut"
                screenButton.Parent = shared.SkidoMobileGui
                screenButton.Size = UDim2.new(0, 75, 0, 28)
                
                local initialYOffset = (shared.SkidoMobileOffsetCount % 10) * 33
                screenButton.Position = UDim2.new(1, -90, 0.35, initialYOffset)
                shared.SkidoMobileOffsetCount = shared.SkidoMobileOffsetCount + 1
                
                screenButton.Font = Enum.Font.GothamBold
                screenButton.Text = togglename or "Toggle"
                screenButton.TextSize = 9.000
                screenButton.TextWrapped = true
                
                screenCorner.CornerRadius = UDim.new(0, 5)
                screenCorner.Parent = screenButton
                
                UpdateScreenButtonVisuals()
                screenButton.MouseButton1Down:Connect(function() FireToggle(false) end)
                
                local dragging = false
                local dragInput, dragStart, startPos
                
                screenButton.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        dragStart = input.Position
                        startPos = screenButton.Position
                        
                        input.Changed:Connect(function()
                            if input.UserInputState == Enum.UserInputState.End then
                                dragging = false
                            end
                        end)
                    end
                end)
                
                screenButton.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
                        dragInput = input
                    end
                end)
                
                mobileDragConn = UserInputService.InputChanged:Connect(function(input)
                    if input == dragInput and dragging then
                        local delta = input.Position - dragStart
                        screenButton.Position = UDim2.new(
                            startPos.X.Scale, startPos.X.Offset + delta.X, 
                            startPos.Y.Scale, startPos.Y.Offset + delta.Y
                        )
                    end
                end)
            end
        end)
    else
        BindButton.MouseButton1Down:Connect(function()
            BindButton.Text = "..."
            BindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            
            -- FIX: Wait a fraction of a second so the initial left-click isn't caught by the listener
            task.wait(0.1) 
            isListening = true
        end)

        UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
            if isListening then
                -- LISTENING MODE: Determine what type of input was just pressed
                local isKeyboard = (input.UserInputType == Enum.UserInputType.Keyboard)
                local isMouse = (input.UserInputType == Enum.UserInputType.MouseButton1 or 
                                 input.UserInputType == Enum.UserInputType.MouseButton2 or 
                                 input.UserInputType == Enum.UserInputType.MouseButton3)

                if isKeyboard or isMouse then
                    if (isKeyboard and (input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace)) then
                        currentBind = nil
                        BindButton.Text = "None"
                    else
                        if isKeyboard then
                            currentBind = input.KeyCode
                            BindButton.Text = currentBind.Name
                        else
                            currentBind = input.UserInputType
                            -- Shorten names for UI: MouseButton1 -> MB1
                            BindButton.Text = string.gsub(currentBind.Name, "MouseButton", "MB")
                        end
                    end
                    BindButton.TextColor3 = Color3.fromRGB(150, 150, 150)
                    isListening = false
                end
            else
                -- ACTIVE MODE: Check if the input matches our saved currentBind
                if not gameProcessedEvent and currentBind and BindButton.Visible then
                    local isMatch = false
                    
                    -- Check for Keyboard Match
                    if typeof(currentBind) == "EnumItem" and currentBind.EnumType == Enum.KeyCode then
                        if input.KeyCode == currentBind then isMatch = true end
                    -- Check for Mouse Match
                    elseif typeof(currentBind) == "EnumItem" and currentBind.EnumType == Enum.UserInputType then
                        if input.UserInputType == currentBind then isMatch = true end
                    end
                    
                    if isMatch then
                        FireToggle(false)
                    end
                end
            end
        end)
    end

    FireToggle(true)
end
