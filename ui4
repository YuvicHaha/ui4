                ToggleHolder.Size = UDim2.new(0, 288, 0, 146)
            else
                closeColorPanel()
            end
        end)

        local isDraggingColor = false

        local function UpdateLiveColor(input)
            local size = ColorCanvas.AbsoluteSize
            local pos = ColorCanvas.AbsolutePosition
            local mousePos = input.Position

            local pctX = math.clamp((mousePos.X - pos.X) / size.X, 0, 1)
            local pctY = math.clamp((mousePos.Y - pos.Y) / size.Y, 0, 1)

            PickerCircle.Position = UDim2.new(pctX, 0, pctY, 0)
            
            currentColor = Color3.fromHSV(pctX, 1 - pctY, 1)
            
            ColorButton.BackgroundColor3 = currentColor
            PickerCircle.BackgroundColor3 = currentColor 
            pcall(colorCallback, currentColor)
        end

        ColorCanvas.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isDraggingColor = true
                UpdateLiveColor(input)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if isDraggingColor and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                UpdateLiveColor(input)
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isDraggingColor = false
            end
        end)
